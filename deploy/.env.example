# Copie para .env e preencha. NÃO versione o .env (já está no .gitignore).

# ── Painel web ───────────────────────────────────────────────────────────────
PAINEL_USUARIO=admin
# Senha do painel — escolha UMA das duas formas:
#  (a) PAINEL_SENHA: senha em texto (prático, ex.: no Dokploy).
PAINEL_SENHA=
#  (b) PAINEL_SENHA_HASH: hash bcrypt (mais seguro; tem prioridade sobre a de texto).
#      Gere com:  python -m sistema_forex.scripts.gerar_hash
PAINEL_SENHA_HASH=
# Chave para assinar o cookie de sessão. Gere uma aleatória:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
SESSAO_HORAS=12

# ── Login do terminal MT5 no navegador (VNC do container gmag11) ──────────────
VNC_USER=trader
VNC_PASSWORD=troque-esta-senha

# ── Conexão MT5 (referência; o login é feito 1x pela tela VNC) ────────────────
MT5_LOGIN=336082748
MT5_SERVER=XMGlobal-MT5 9
MT5_PASSWORD=
MT5_HOST=mt5
MT5_PORT=8001

# ── Coletor ──────────────────────────────────────────────────────────────────
COLETOR_POLL_S=5
LOG_LEVEL=DEBUG

# ── Motor de análise (Fase 2) ────────────────────────────────────────────────
ANALISE_POLL_S=15

# ── Estrategista (Fase 4 — modo sombra) ──────────────────────────────────────
DECISAO_POLL_S=5

# ── Painel ───────────────────────────────────────────────────────────────────
# Auto-refresh do status (segundos) — fetch leve do /api/status, sem recarregar o gráfico.
PAINEL_REFRESH_S=5

# ── Telegram (usado a partir das próximas fases) ─────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT=
