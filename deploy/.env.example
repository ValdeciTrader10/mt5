# Copie para .env e preencha. NÃO versione o .env (já está no .gitignore).

# ── Painel web ───────────────────────────────────────────────────────────────
PAINEL_USUARIO=admin
# Senha do painel — escolha UMA das duas formas:
#  (a) PAINEL_SENHA: senha em texto (prático, ex.: no Dokploy).
PAINEL_SENHA=
#  (b) PAINEL_SENHA_HASH: hash bcrypt (mais seguro; tem prioridade sobre a de texto).
#      Gere com:  python -m sistema_forex.scripts.gerar_hash
PAINEL_SENHA_HASH=
# Chave para assinar o cookie de sessão. Gere uma aleatória:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
SESSAO_HORAS=12

# ── Login do terminal MT5 no navegador (VNC do container gmag11) ──────────────
VNC_USER=trader
VNC_PASSWORD=troque-esta-senha

# ── Conexão MT5 (referência; o login é feito 1x pela tela VNC) ────────────────
MT5_LOGIN=336082748
MT5_SERVER=XMGlobal-MT5 9
MT5_PASSWORD=
MT5_HOST=mt5
MT5_PORT=8001

# ── Coletor ──────────────────────────────────────────────────────────────────
COLETOR_POLL_S=5
LOG_LEVEL=DEBUG

# ── B3 / Genial (ETAPA 8 — feed WIN/WDO) ─────────────────────────────────────
# 2º terminal MT5 (container mt5_b3), logado na GENIAL via VNC na porta 3101.
# Conta REAL usada SÓ para cotações (nenhuma ordem — a ponte do B3 é data-only).
B3_HABILITADO=true
# Símbolos B3. Confirme o nome exato na Market Watch da Genial (VNC :3101) e ajuste.
# WIN$N/WDO$N = contratos contínuos (rolagem). Aliases tentados: WIN$, WINFUT, etc.
PARES_B3=WIN$N,WDO$N
COLETOR_B3_POLL_S=5
# ── Sombra da B3 (ETAPA 8b) — estrategista + executor de sombra (WIN/WDO) ─────
# Roda as mesmas estratégias sobre WIN/WDO e SIMULA as operações ao vivo (P&L em BRL,
# ponte data-only — nenhuma ordem real). Isolado do forex (decisões/trades mercado='b3').
B3_SOMBRA_HABILITADA=true
# TFs de operação da sombra da B3 (cada TF é um livro independente, como no forex).
TFS_OPERACAO_B3=M1,M5,M15
# Nº de contratos da posição de sombra (P&L = pontos × valor-por-ponto × contratos).
CONTRATOS_B3=1
# Polls (s) do estrategista e do executor de sombra da B3.
DECISAO_B3_POLL_S=5
GESTOR_B3_POLL_S=1
# Login do terminal Genial (referência; o login é feito 1x pela tela VNC :3101).
MT5_B3_LOGIN=
MT5_B3_SERVER=
MT5_B3_PASSWORD=
MT5_B3_HOST=mt5_b3
MT5_B3_PORT=8001
# Calibração de escala (Etapa 8b) — derivada dos candles; ajuste raro. Ver /b3 ou
# `python -m sistema_forex.calibracao_b3`. TF base do SL, janela e multiplicador de ATR.
CALIB_TF_BASE=M5
CALIB_JANELA=1500
CALIB_SL_MULT=3.0

# ── Motor de análise (Fase 2) ────────────────────────────────────────────────
ANALISE_POLL_S=15

# ── Estrategista (Fase 4 — modo sombra) ──────────────────────────────────────
DECISAO_POLL_S=5

# ── Executor + gestor de saída (Fase 5) ──────────────────────────────────────
# TRAVA DE SEGURANÇA: false = simulação sobre preço ao vivo (NÃO envia ordens).
# true = opera de verdade na conta demo (exige "Algo Trading" habilitado no MT5).
EXECUCAO_ATIVA=false
GESTOR_POLL_S=1

# ── Painel ───────────────────────────────────────────────────────────────────
# Auto-refresh do status (segundos) — fetch leve do /api/status, sem recarregar o gráfico.
PAINEL_REFRESH_S=5

# ── Telegram (usado a partir das próximas fases) ─────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT=
